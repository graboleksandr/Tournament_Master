<Window x:Class="Tournament_Master.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tournament Master" Height="750" Width="1300"
        WindowStartupLocation="CenterScreen" 
        Background="{DynamicResource WindowBg}">
    <Window.Resources>
        <SolidColorBrush x:Key="LoginOrange" Color="{DynamicResource AccentColorValue}"/>
        <SolidColorBrush x:Key="SidebarCream" Color="{DynamicResource SidebarBgValue}"/>
        <SolidColorBrush x:Key="TextBrown" Color="{DynamicResource PrimaryTextValue}"/>

        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Margin" Value="10,5"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="20,0,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="15">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource HoverColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{DynamicResource SidebarBg}" CornerRadius="0,30,30,0">
            <StackPanel Margin="10,30">
                <TextBlock Text="TOURNAMENT" 
                           Foreground="{DynamicResource AccentColor}" 
                           FontSize="22" FontWeight="Bold" 
                           HorizontalAlignment="Center" Margin="0,0,0,40"/>

                <Button Click="BtnHome_Click" Style="{StaticResource MenuButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="" Margin="0,0,15,0" Foreground="{DynamicResource AccentColor}"/>
                        <TextBlock Text="{DynamicResource m_Home}"/>
                    </StackPanel>
                </Button>

                <Button Click="BtnParticipants_Click" Style="{StaticResource MenuButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="" Margin="0,0,15,0" Foreground="{DynamicResource AccentColor}"/>
                        <TextBlock Text="{DynamicResource m_Players}"/>
                    </StackPanel>
                </Button>

                <Button Click="BtnTeams_Click" Style="{StaticResource MenuButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="" Margin="0,0,15,0" Foreground="{DynamicResource AccentColor}"/>
                        <TextBlock Text="{DynamicResource m_Teams}"/>
                    </StackPanel>
                </Button>

                <Button Click="BtnSchedule_Click" Style="{StaticResource MenuButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="" Margin="0,0,15,0" Foreground="{DynamicResource AccentColor}"/>
                        <TextBlock Text="{DynamicResource m_Schedule}"/>
                    </StackPanel>
                </Button>

                <Button Click="BtnNavigateLeaderboard_Click" Style="{StaticResource MenuButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="" Margin="0,0,15,0" Foreground="{DynamicResource AccentColor}"/>
                        <TextBlock Text="{DynamicResource m_Leaderboard}"/>
                    </StackPanel>
                </Button>

                <Separator Margin="20,30" Background="{DynamicResource PrimaryText}" Opacity="0.2"/>

                <Button Click="BtnSettings_Click" Style="{StaticResource MenuButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="" Margin="0,0,15,0" Foreground="{DynamicResource AccentColor}"/>
                        <TextBlock Text="{DynamicResource SettingsHeader}"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <Frame x:Name="MainFrame" Grid.Column="1" NavigationUIVisibility="Hidden"/>
    </Grid>
</Window>