<Window x:Class="Tournament_Master.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tournament Master - Керування командами" Height="500" Width="800"
        WindowStartupLocation="CenterScreen">

    <Grid Background="#F3F3F3">
        <StackPanel Margin="30" MaxWidth="500">
            <TextBlock Text="Назва нової команди:" FontSize="16" Margin="0,0,0,5"/>

            <TextBox x:Name="TeamNameInput" 
                     FontSize="18" 
                     Padding="5" 
                     Margin="0,0,0,15"/>

            <Button Content="Додати в список" 
                    Height="40" 
                    Click="AddTeam_Click" 
                    Background="#2196F3" 
                    Foreground="White"
                    FontSize="16"
                    Cursor="Hand"/>

            <Separator Margin="0,20"/>

            <TextBlock Text="Список команд:" FontSize="16" Margin="0,0,0,5"/>
            <ListBox x:Name="TeamsListBox" Height="200" FontSize="16"/>
        </StackPanel>
    </Grid>
</Window>