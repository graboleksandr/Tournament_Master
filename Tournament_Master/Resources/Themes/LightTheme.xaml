<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="WindowBg" Color="#F5F5F5"/>
    <SolidColorBrush x:Key="PrimaryText" Color="#333333"/>
    <SolidColorBrush x:Key="AccentColor" Color="#FFB900"/>
    <Color x:Key="AccentColorValue">#F9A11B</Color>
    <Color x:Key="SidebarBgValue">#F2E8C9</Color>
    <SolidColorBrush x:Key="SidebarBg" Color="#F2E8C9"/>
    <SolidColorBrush x:Key="HoverColor" Color="#EBD9A9"/>
</ResourceDictionary>