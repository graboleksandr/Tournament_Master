<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="WindowBg" Color="#1E1E1E"/>
    <SolidColorBrush x:Key="PrimaryText" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="AccentColor" Color="#FFCC00"/>
    <Color x:Key="AccentColorValue">#FFB900</Color>
    <Color x:Key="SidebarBgValue">#252525</Color>
    <SolidColorBrush x:Key="SidebarBg" Color="#252525"/>
    <SolidColorBrush x:Key="HoverColor" Color="#3D3D3D"/>
</ResourceDictionary>