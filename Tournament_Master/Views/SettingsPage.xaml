<Page x:Class="Tournament_Master.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="clr-namespace:Tournament_Master.Controls" 
      Title="SettingsPage"
      Background="{DynamicResource WindowBg}">

    <Page.Resources>
        <Style x:Key="SettingLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="25,0,0,0"/>
        </Style>
        <Style x:Key="SettingRowStyle" TargetType="Border">
            <Setter Property="Height" Value="60"/>
        </Style>
    </Page.Resources>

    <Grid Margin="0,30,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="{DynamicResource SettingsHeader}" FontSize="22" FontWeight="SemiBold" 
                   Foreground="{DynamicResource AccentColor}" Margin="40,0,0,25"/>

        <ScrollViewer Grid.Row="1" Margin="15,0,15,0">
            <StackPanel>
                <Separator Background="{DynamicResource PrimaryText}" Opacity="0.1"/>
                <Border Style="{StaticResource SettingRowStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{DynamicResource ThemeOption}" Style="{StaticResource SettingLabelStyle}"/>
                        <controls:CyclicSelector x:Name="ThemeSelector" Grid.Column="1" Width="200" 
                                                 HorizontalAlignment="Right" Margin="0,0,15,0"
                                                 SelectionChanged="ThemeSelector_SelectionChanged"/>
                    </Grid>
                </Border>
                <Separator Background="{DynamicResource PrimaryText}" Opacity="0.1"/>
                <Border Style="{StaticResource SettingRowStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{DynamicResource LangOption}" Style="{StaticResource SettingLabelStyle}"/>
                        <controls:CyclicSelector x:Name="LanguageSelector" Grid.Column="1" Width="200" 
                                                 HorizontalAlignment="Right" Margin="0,0,15,0"
                                                 SelectionChanged="LanguageSelector_SelectionChanged"/>
                    </Grid>
                </Border>
                <Separator Background="{DynamicResource PrimaryText}" Opacity="0.1"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>