<Window x:Class="Tournament_Master.Views.AddParticipantWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Додати учасника" Height="250" Width="300" WindowStartupLocation="CenterScreen" Background="#1E1E1E" Foreground="White">
    <StackPanel Margin="20">
        <TextBlock Text="Ім'я:" Margin="0,0,0,5"/>
        <TextBox x:Name="TxtFirstName" Margin="0,0,0,15" Padding="5"/>

        <TextBlock Text="Прізвище:" Margin="0,0,0,5"/>
        <TextBox x:Name="TxtLastName" Margin="0,0,0,20" Padding="5"/>

        <TextBlock x:Name="ErrorLabel" 
               Foreground="Red" 
               FontSize="12" 
               HorizontalAlignment="Center" 
               Margin="0,0,0,10" 
               Visibility="Collapsed" 
               TextWrapping="Wrap"/>
        
        <Button Content="Зберегти" Click="BtnSave_Click" Height="35" Background="#FFB10C" Foreground="White" FontWeight="Bold"/>
    </StackPanel>
</Window>