<Page x:Class="Tournament_Master.Views.ParticipantsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:Tournament_Master"
      Background="{DynamicResource WindowBg}">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <Style x:Key="ButtonTextBlockStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style x:Key="ImportButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource SidebarBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}" 
                                BorderBrush="{DynamicResource HoverColor}" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AddButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource AccentColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{DynamicResource SidebarBg}" CornerRadius="15" Padding="15,5" Margin="0,0,20,0">
                <Grid>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="" Foreground="{DynamicResource PrimaryText}" Opacity="0.5" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Grid>
                            <TextBlock Text="{DynamicResource m_Search}" Foreground="{DynamicResource PrimaryText}" Opacity="0.5" VerticalAlignment="Center"
                                       Visibility="{Binding ElementName=TxtSearch, Path=Text.IsEmpty, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            <TextBox x:Name="TxtSearch" Background="Transparent" BorderThickness="0" Width="400"
                                     Foreground="{DynamicResource PrimaryText}" VerticalContentAlignment="Center" TextChanged="TxtSearch_TextChanged"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Style="{StaticResource ImportButtonStyle}" Click="BtnImport_Click" Margin="0,0,10,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="" Margin="0,0,8,0" VerticalAlignment="Center" Foreground="{DynamicResource PrimaryText}"/>
                        <TextBlock Text="{DynamicResource m_Import}" Foreground="{DynamicResource PrimaryText}" VerticalAlignment="Center" FontSize="14"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource AddButtonStyle}" Click="BtnAddManual_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="+" FontWeight="Bold" Margin="0,0,5,0" VerticalAlignment="Center" Foreground="White"/>
                        <TextBlock Text="{DynamicResource m_AddBtn}" Foreground="White" VerticalAlignment="Center" FontSize="14"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="ParticipantsCards" ItemsSource="{Binding Source={x:Static local:DataStorage.AllParticipants}}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="200" Margin="10" Background="{DynamicResource SidebarBg}" CornerRadius="12" BorderBrush="{DynamicResource HoverColor}" BorderThickness="1">
                            <Grid>
                                <StackPanel Margin="15">
                                    <TextBlock Text="{Binding FirstName}" FontWeight="Bold" Foreground="{DynamicResource PrimaryText}" FontSize="16"/>
                                    <TextBlock Text="{Binding LastName}" Foreground="{DynamicResource AccentColor}" FontSize="14"/>
                                </StackPanel>
                                <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Top" 
                                        Background="Transparent" BorderThickness="0" Foreground="{DynamicResource PrimaryText}" 
                                        Opacity="0.6" Margin="5" Click="BtnDelete_Click"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <TextBlock x:Name="LblStats" Grid.Row="2" Text="{DynamicResource m_TotalPlayers}" Foreground="{DynamicResource PrimaryText}" Opacity="0.6" Margin="0,10,0,0"/>
    </Grid>
</Page>