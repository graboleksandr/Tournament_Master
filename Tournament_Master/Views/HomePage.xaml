<Page x:Class="Tournament_Master.Views.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Home" Background="{DynamicResource WindowBg}"
      SnapsToDevicePixels="True" 
      UseLayoutRounding="True"
      TextOptions.TextFormattingMode="Display">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="TOURNAMENT MASTER" 
                   FontSize="36" FontWeight="ExtraBold" Foreground="{DynamicResource AccentColor}" 
                   HorizontalAlignment="Center" Margin="0,0,0,30">
            <TextBlock.Effect>
                <DropShadowEffect BlurRadius="5" ShadowDepth="1" Opacity="0.2" Color="{DynamicResource AccentColorValue}"/>
            </TextBlock.Effect>
        </TextBlock>

        <StackPanel Grid.Row="1">
            <TextBlock Text="{DynamicResource m_RecentTournaments}" FontSize="20" 
                       FontWeight="SemiBold" Foreground="{DynamicResource PrimaryText}" Margin="10,0,0,20"/>

            <ListBox x:Name="RecentTournamentsList" 
                     Background="Transparent" 
                     BorderThickness="0"
                     HorizontalContentAlignment="Stretch"
                     SelectionChanged="RecentTournamentsList_SelectionChanged">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Margin" Value="0,0,0,10"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="itemBorder" 
                                            Background="{DynamicResource SidebarBg}" 
                                            CornerRadius="15" 
                                            Padding="15,10" 
                                            BorderBrush="{DynamicResource HoverColor}"
                                            BorderThickness="1">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.1" Color="{DynamicResource PrimaryTextValue}"/>
                                        </Border.Effect>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="65"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Image Source="pack://application:,,,/Tournament_Master;component/Resources/Images/cup_icon.png" 
                                                   Grid.Column="0" Height="45" Width="45" VerticalAlignment="Center" HorizontalAlignment="Left"
                                                   RenderOptions.BitmapScalingMode="HighQuality"/>

                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="5,0">
                                                <Grid>
                                                    <TextBlock x:Name="DisplayTitle" Text="{Binding Title}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource AccentColor}"/>
                                                    <TextBox x:Name="EditTitle" Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" 
                                                             FontSize="18" FontWeight="Bold" Foreground="{DynamicResource AccentColor}" Background="{DynamicResource WindowBg}"
                                                             Visibility="Collapsed" LostFocus="EditTitle_LostFocus" KeyDown="EditTitle_KeyDown"/>
                                                </Grid>
                                                <TextBlock Text="{Binding Info}" FontSize="13" Foreground="{DynamicResource PrimaryText}" Opacity="0.7" Margin="0,2,0,0"/>
                                            </StackPanel>

                                            <TextBlock Text="{Binding Date}" Grid.Column="2" VerticalAlignment="Center" 
                                                       FontSize="11" Foreground="{DynamicResource PrimaryText}" Opacity="0.5" Margin="15,0,10,0"/>

                                            <Button Grid.Column="3" Content="✕" 
                                                    Click="BtnDeleteTournament_Click"
                                                    FontSize="16" Foreground="#D32F2F" 
                                                    Background="Transparent" BorderThickness="0"
                                                    VerticalAlignment="Center" Padding="5" 
                                                    Cursor="Hand" ToolTip="Видалити турнір"/>
                                        </Grid>
                                    </Border>

                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="itemBorder" Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
                                            <Setter TargetName="itemBorder" Property="Background" Value="{DynamicResource HoverColor}"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="itemBorder" Property="Background" Value="{DynamicResource HoverColor}"/>
                                            <Setter TargetName="DisplayTitle" Property="Visibility" Value="Collapsed"/>
                                            <Setter TargetName="EditTitle" Property="Visibility" Value="Visible"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>
        </StackPanel>
    </Grid>
</Page>